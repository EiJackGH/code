<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mario Game</title>

  <style>
    body {
      margin: 0;
      background: #5c94fc;
      overflow: hidden;
    }

    #game {
      position: relative;
      width: 100vw;
      height: 100vh;
    }

    /* Mario sprite */
    #mario {
      position: absolute;
      width: 48px;
      height: 48px;
      bottom: 50px;
      left: 100px;
      background: url("https://i.imgur.com/Wb1qfhK.png") no-repeat center/cover;
    }

    /* Goomba sprite */
    .goomba {
      position: absolute;
      width: 40px;
      height: 40px;
      bottom: 50px;
      background: url("https://i.imgur.com/6X12GQp.png") no-repeat center/cover;
    }

    .ground {
      position: absolute;
      bottom: 0;
      width: 100%;
      height: 50px;
      background: #2ecc71;
    }

    #score {
      position: absolute;
      top: 10px;
      left: 10px;
      color: white;
      font-size: 20px;
      font-family: Arial;
    }

    #controls {
      position: absolute;
      top: 40px;
      left: 10px;
      color: rgba(255, 255, 255, 0.8);
      font-size: 14px;
      font-family: Arial;
    }
  </style>
</head>

<body>

<div id="game">
  <div id="score" aria-live="polite" aria-atomic="true">Score: 0</div>
  <div id="controls">Press Space or ↑ to jump</div>
  <div id="mario"></div>
  <div class="ground"></div>
</div>

<script>
  const mario = document.getElementById("mario");
  const game = document.getElementById("game");
  const scoreText = document.getElementById("score");

  let jumping = false;
  let score = 0;

  // Jump mechanic
  document.addEventListener("keydown", (e) => {
    // Prevent default page scrolling for typical game keys
    if (["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(e.code)) {
      e.preventDefault();
    }

    // Only jump on Space or Up Arrow
    if (e.code !== "Space" && e.code !== "ArrowUp") return;

    if (jumping) return;

    jumping = true;
    let position = 50;

    const up = setInterval(() => {
      if (position >= 150) {
        clearInterval(up);

        const down = setInterval(() => {
          if (position <= 50) {
            clearInterval(down);
            jumping = false;
          }
          position -= 5;
          mario.style.bottom = position + "px";
        }, 20);
      }

      position += 5;
      mario.style.bottom = position + "px";
    }, 20);
  });

  // Spawn Goombas
  function spawnGoomba() {
    const goomba = document.createElement("div");
    goomba.classList.add("goomba");
    game.appendChild(goomba);

    let position = window.innerWidth;

    const move = setInterval(() => {
      if (position < -40) {
        clearInterval(move);
        goomba.remove();
        score++;
        scoreText.innerText = "Score: " + score;
      } else {
        position -= 6;
        goomba.style.left = position + "px";
      }

      // Collision detection
      const marioBottom = parseInt(window.getComputedStyle(mario).bottom);

      if (position > 80 && position < 140 && marioBottom < 90) {
        alert("Game Over! Score: " + score);
        location.reload();
      }

    }, 20);

    setTimeout(spawnGoomba, Math.random() * 2000 + 1000);
  }

  spawnGoomba();
</script>

</body>
</html>
